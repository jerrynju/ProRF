<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Window-level theme used before Compose's ProRfTheme takes over.
        Compose handles all color/typography. This only sets the initial window chrome.
    -->
    <style name="Theme.ProRF" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
